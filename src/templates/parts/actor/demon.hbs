<section class="demon">
  <div class="items-list flexcol">
    <ol class="stat-list">
      <li class="item flexrow items-header">
        <div>{{localize "SMT.charClasses.demon"}}</div>
      </li>

      <li class="item flexrow">
        <div class="item-prop">{{localize "SMT.bioData.personality"}}</div>
        <input class="flex3" type="text" name="system.personality" value="{{system.personality}}" placeholder="N/A"
          data-dtype="String" />
      </li>

      <li class="item flexrow">
        <div class="item-prop">{{localize "SMT.bioData.inheritType"}}</div>
        <input class="flex3" type="text" name="system.inheritType" value="{{system.inheritType}}" placeholder="N/A"
          data-dtype="String" />
      </li>

      <li class="item flexrow">
        <div class="item-prop">{{localize "SMT.bioData.evolvePath"}}</div>
        <input class="flex3" type="text" name="system.evolvePath" value="{{system.evolvePath}}" placeholder="N/A"
          data-dtype="String" />
      </li>
    </ol>
  </div>
</section>